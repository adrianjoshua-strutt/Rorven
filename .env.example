RORVEN_OPENROUTER_API_KEY=

# Optional. If omitted, Rorven lets OpenRouter use its provider default route.
# You can also set per-profile values here instead of editing config/model-profiles.
RORVEN_MODEL_PROFILE_UTILITY=
RORVEN_MODEL_PROFILE_BALANCED=
RORVEN_MODEL_PROFILE_REASONING=
RORVEN_MODEL_PROFILE_FRONTIER=

# Optional.
RORVEN_MODEL_GATEWAY=auto
RORVEN_RUNTIME_ADAPTER=langgraph
RORVEN_DATA_DIR=.rorven
